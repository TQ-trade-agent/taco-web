    "dayjs": "^1.11.10",
    "echarts": "^5.4.3",
    "lodash-es": "^4.17.21",
    "marked": "^16.2.0",
    "mermaid": "^10",
    "nprogress": "^0.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.1",
