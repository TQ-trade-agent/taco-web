{
  "name": "tradingagents-cn",
  "version": "1.0.1",
  "description": "TradingAgents-CN — 多智能体股票分析（TypeScript / Node.js，中文场景）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "example": "tsx examples/run-analysis.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "trading",
    "agents",
    "langgraph",
    "china",
    "a-share",
    "typescript",
    "nodejs"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "api-ts-utils": "^3.5.9",
    "dotenv": "^16.4.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
